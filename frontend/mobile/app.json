{
  "expo": {
    "name": "Agromarket ULEAM",
    "slug": "agromarket-uleam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a5c1a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a5c1a"
      },
      "package": "ec.uleam.fcvt.agromarket",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ec.uleam.fcvt.agromarket"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Agromarket necesita acceso a tu galería para subir el comprobante de pago.",
          "cameraPermission": "Agromarket necesita acceso a la cámara para fotografiar el comprobante de pago."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Agromarket necesita acceso a la cámara para escanear el código QR del cliente."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a5c1a"
        }
      ],
      "expo-image",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2427bbdd-147b-4f6c-893c-a6d9a94f7f6c"
      }
    },
    "owner": "lugon2702"
  }
}
