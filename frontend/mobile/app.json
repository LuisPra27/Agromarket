{
  "expo": {
    "name": "Agromarket ULEAM",
    "slug": "agromarket-uleam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a5c1a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a5c1a"
      },
      "package": "ec.uleam.fcvt.agromarket",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ec.uleam.fcvt.agromarket"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Agromarket necesita acceso a tu galería para subir el comprobante de pago.",
          "cameraPermission": "Agromarket necesita acceso a la cámara para fotografiar el comprobante de pago."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Agromarket necesita acceso a la cámara para escanear el código QR del cliente."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a5c1a"
        }
      ],
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "7e25326d-835f-41bc-831f-c73a13fd4199"
      }
    }
  }
}
